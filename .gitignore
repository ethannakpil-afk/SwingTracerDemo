# ---- Python ----
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class

# ---- OS / editor junk ----
.DS_Store
.vscode/

# ---- Runtime-generated data (regenerated by the app) ----
# Keep the folders (.gitkeep) but ignore their contents
uploads/*
static/outputs/*
static/output/*
reports/*

# ...but don't ignore the .gitkeep placeholders
!uploads/.gitkeep
!static/outputs/.gitkeep
!static/output/.gitkeep
!reports/.gitkeep

# ---- Old template backups ----
templates/index_backup_*.html
templates/index_working_video.html
